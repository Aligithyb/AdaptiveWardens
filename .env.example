# Database
DATABASE_PATH=/data/honeypot.db
SQLITE_TIMEOUT=30

# AI Engine
AI_MODEL=distilgpt2
AI_DEVICE=cpu
AI_MAX_LENGTH=512
AI_TEMPERATURE=0.7
RESPONSE_CACHE_SIZE=1000

# SSH Frontend
SSH_PORT=2222
SSH_HOST=0.0.0.0

# HTTP Frontend
HTTP_PORT=8080
HTTP_HOST=0.0.0.0

# Dashboard
DASHBOARD_PORT=3000
API_PORT=8000
JWT_SECRET=CHANGE_THIS_SECRET_KEY_IN_PRODUCTION
JWT_EXPIRY=3600

# Service URLs (internal Docker network)
SANDBOX_URL=http://sandbox-store:8001
AI_ENGINE_URL=http://ai-engine:8002
DASHBOARD_URL=http://dashboard-backend:8000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
ENABLE_RATE_LIMITING=true
MAX_SESSIONS=50
SESSION_TIMEOUT=1800
