# Database
DATABASE_PATH=/data/honeypot.db
SQLITE_TIMEOUT=30

# AI Engine
AI_MODEL=distilbert-base-uncased
AI_MAX_LENGTH=512
AI_TEMPERATURE=0.7
RESPONSE_CACHE_SIZE=1000

# SSH Frontend
SSH_PORT=2222
SSH_HOST_KEY=/configs/ssh_host_key

# HTTP Frontend
HTTP_PORT=8080
HTTP_HOST=0.0.0.0

# Dashboard
DASHBOARD_PORT=3000
API_PORT=8000
JWT_SECRET=CHANGE_THIS_SECRET_KEY
JWT_EXPIRY=3600

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
ENABLE_RATE_LIMITING=true
MAX_SESSIONS=50
SESSION_TIMEOUT=1800

# Slack Integration
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#alerts
