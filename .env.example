# ==========================================
# AdaptiveWardens - Environment Configuration
# ==========================================

# --- Core Configuration ---
# Protocol ports
SSH_PORT=2222
HTTP_PORT=8080
DASHBOARD_PORT=3000
SANDBOX_API_PORT=8001

# --- AI Engine ---
# DeepSeek — get a key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com   # uncomment to override

# --- LLM cost circuit breaker ---
# Once either daily ceiling is hit, the AI engine falls back to deterministic
# / static responses for the remainder of the UTC day. Counters reset at 00:00
# UTC and survive container restarts (persisted under /data/llm_budget.db).
# Defaults are tight (~$0.40/month worst case) so a small DeepSeek balance
# can't be drained overnight. Raise once you've calibrated.
LLM_DAILY_INPUT_TOKEN_BUDGET=50000
LLM_DAILY_OUTPUT_TOKEN_BUDGET=20000

# Per-attacker rate limit on LLM calls (one noisy IP can't burn the day's
# budget in seconds). After CALLS misses inside WINDOW seconds, that IP gets
# fallback output until the window slides.
LLM_PER_IP_RATE_LIMIT_CALLS=30
LLM_PER_IP_RATE_LIMIT_WINDOW=60

# --- Slack Alerts ---
# Option 1: Using Incoming Webhooks (Recommended)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TXXX/BXXX/XXXX

# Option 2: Using Bot Token (Requires chat:write scope)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL=#alerts

# --- SOAR Integration ---
# Generic webhook fired on every new session. Leave blank to disable.
# Compatible with XSOAR, Tines, n8n, Splunk SOAR, or any HTTP receiver.
SOAR_WEBHOOK_URL=

# --- SIEM / CEF Export ---
# CEF-formatted session exports are available at:
#   GET /api/integrations/siem/cef/{session_id}  — single session
#   GET /api/integrations/siem/cef?limit=200      — bulk export
# Point your syslog forwarder at the dashboard-backend on port 8003.

# --- Database & Storage ---
DB_PATH=/data/app_state.db
SQLITE_TIMEOUT=30

# --- Dashboard & Security ---
JWT_SECRET=super-secret-key-change-me
JWT_EXPIRY=3600
LOG_LEVEL=INFO
# REQUIRED — no default. Choose a strong password before starting.
DASHBOARD_PASSWORD=
# REQUIRED — no default. Generate with: openssl rand -hex 32
SESSION_SECRET=
# Public URL of the dashboard-backend (shown in browser). Set to your server's IP/domain.
NEXT_PUBLIC_API_URL=http://localhost:8003

# --- Session Limits ---
MAX_SESSIONS=50
SESSION_TIMEOUT=1800
ENABLE_RATE_LIMITING=true

# --- Canary Tokens (optional but recommended) ---
# Generate real tokens at https://canarytokens.org/generate
# Choose "AWS Keys" token → paste the Access Key ID + Secret below.
# If an attacker uses these keys anywhere on the internet, canarytokens.org
# sends you an instant alert with the attacker's real IP — even outside the honeypot.
#
# For the DNS token: choose "DNS" token → paste the hostname below.
# Any DNS lookup of that hostname (e.g. from nslookup in your honeypot) triggers an alert.
#
# If these are left blank, convincing-looking static values are used automatically.
CANARY_AWS_ACCESS_KEY=
CANARY_AWS_SECRET_KEY=
CANARY_STRIPE_KEY=
CANARY_DNS_HOSTNAME=

# --- HTTP Honeypot ---
# All requests from the same IP within this window (seconds) are grouped into
# one session. Prevents bots from flooding the dashboard with thousands of sessions.
HTTP_SESSION_WINDOW=300          # 5 minutes
# Stop logging commands after this many per session (still respond to requests).
HTTP_MAX_CMDS_PER_SESSION=60

# --- Threat Intelligence ---
# VirusTotal: free tier at https://www.virustotal.com/gui/my-apikey
# Free limits: 4 requests/min, 500/day — the cache handles this automatically.
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# AbuseIPDB: free tier at https://www.abuseipdb.com/account/api
# Free limits: 1000 checks/day — again, cache makes this a non-issue.
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# --- Azure Front Door + WAF ---
# Optional: Set this to verify requests come through YOUR Front Door instance.
# Retrieve from: az afd profile show --profile-name aw-afd --query properties.frontDoorId
# Leave blank to skip verification (requests from any FD or direct access accepted).
FRONTDOOR_FDID=

# Geo-filtering: comma-separated ISO country codes to ALLOW.
# Empty = allow all countries (geo-filtering disabled).
# Example: US,GB,CA,AU,DE,FR,NL,SE,NO,DK,FI,IE
ALLOWED_COUNTRIES=

# Rate limit: max requests per client IP per minute at the WAF edge
FRONTDOOR_RATE_LIMIT=200

# GitHub Secret reference for Front Door + WAF Bicep deployment:
#   AZURE_RG=AdaptiveWardens
# These are set as GitHub Actions secrets — no local config needed for deployment.
