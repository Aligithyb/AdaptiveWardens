# ==========================================
# AdaptiveWardens - Environment Configuration
# ==========================================

# --- Core Configuration ---
# Protocol ports
SSH_PORT=2222
HTTP_PORT=8080
DASHBOARD_PORT=3000
SANDBOX_API_PORT=8001

# --- AI Engine ---
# DeepSeek — get a key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com   # uncomment to override

# --- Slack Alerts ---
# Option 1: Using Incoming Webhooks (Recommended)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TXXX/BXXX/XXXX

# Option 2: Using Bot Token (Requires chat:write scope)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL=#alerts

# --- Database & Storage ---
DB_PATH=/data/app_state.db
SQLITE_TIMEOUT=30

# --- Dashboard & Security ---
JWT_SECRET=super-secret-key-change-me
JWT_EXPIRY=3600
LOG_LEVEL=INFO

# --- Session Limits ---
MAX_SESSIONS=50
SESSION_TIMEOUT=1800
ENABLE_RATE_LIMITING=true

# --- Canary Tokens (optional but recommended) ---
# Generate real tokens at https://canarytokens.org/generate
# Choose "AWS Keys" token → paste the Access Key ID + Secret below.
# If an attacker uses these keys anywhere on the internet, canarytokens.org
# sends you an instant alert with the attacker's real IP — even outside the honeypot.
#
# For the DNS token: choose "DNS" token → paste the hostname below.
# Any DNS lookup of that hostname (e.g. from nslookup in your honeypot) triggers an alert.
#
# If these are left blank, convincing-looking static values are used automatically.
CANARY_AWS_ACCESS_KEY=
CANARY_AWS_SECRET_KEY=
CANARY_STRIPE_KEY=
CANARY_DNS_HOSTNAME=
